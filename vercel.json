{
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://webbuffmxhbe.onrender.com/api/:path*" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Credentials", "value": "true" },
        { "key": "Access-Control-Allow-Origin", "value": "https://webbuffmxh.vercel.app" }
      ]
    }
  ]
}
